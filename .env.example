TG_TOKEN=your_telegram_bot_token
# Прокси только для Telegram (если api.telegram.org:443 недоступен без VPN):
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890
# TELEGRAM_PROXY_URL=socks5://127.0.0.1:1080
# Один экземпляр polling на машине (файл PID + порт). На сервере не дублируйте с локальным main.py.
# NEUROMULE_TELEGRAM_LOCK_PORT=45678
# NEUROMULE_TELEGRAM_LOCK_FILE=data/telegram_bot.lock

# ЮKassa: токен провайдера из @BotFather (раздел Payments). Пусто — только Stars.
# Можно использовать PAYMENT_TOKEN или UKASSA_PROVIDER_TOKEN.
PAYMENT_TOKEN=
UKASSA_PROVIDER_TOKEN=
SHOP_PAYMENT_TITLE=NeuroMule

# Магазин: пакеты (сетка 2026). Stars — финальная цена с округлением и наценкой.
MINI_ENERGY=500
MINI_CRYSTALS=10
MINI_RUB_KOPECKS=34900
MINI_STARS=250
MINI_DAYS=30
SMART_ENERGY=1500
SMART_CRYSTALS=35
SMART_RUB_KOPECKS=79000
SMART_STARS=570
SMART_DAYS=30
ULTRA_3D_ENERGY=500
ULTRA_3D_CRYSTALS=10
ULTRA_3D_RUB_KOPECKS=29000
ULTRA_3D_STARS=210
ULTRA_3D_DAYS=3
ULTRA_1W_ENERGY=1800
ULTRA_1W_CRYSTALS=35
ULTRA_1W_RUB_KOPECKS=69000
ULTRA_1W_STARS=500
ULTRA_1W_DAYS=7
ULTRA_1M_ENERGY=7000
ULTRA_1M_CRYSTALS=120
ULTRA_1M_RUB_KOPECKS=249000
ULTRA_1M_STARS=1800
ULTRA_1M_DAYS=30
# Legacy aliases (= ULTRA 1 месяц)
ULTRA_ENERGY=7000
ULTRA_CRYSTALS=120
ULTRA_RUB_KOPECKS=249000
ULTRA_STARS=1800
CRYSTALS_10_AMOUNT=10
CRYSTALS_10_RUB_KOPECKS=24900
CRYSTALS_10_STARS=180
CRYSTALS_40_AMOUNT=40
CRYSTALS_40_RUB_KOPECKS=69000
CRYSTALS_40_STARS=500
CRYSTALS_100_AMOUNT=100
CRYSTALS_100_RUB_KOPECKS=149000
CRYSTALS_100_STARS=1080
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_CHAT_URL=https://openrouter.ai/api/v1/chat/completions
GEMINI_API_KEY=your_google_ai_key
# Лимит выходных токенов (тело запроса max_tokens); имена env = полям Settings в UPPER_CASE.
OPENROUTER_MAX_OUTPUT_TOKENS=640
OPENROUTER_PREMIUM_MAX_OUTPUT_TOKENS=2500

# telegram | vk | max | api | wb_worker
NEUROMULE_PLATFORM=telegram
VK_TOKEN=
MAX_TOKEN=
API_PORT=8000

# WB API nightly worker (NEUROMULE_PLATFORM=wb_worker): батч по API + утро 09:00 МСК
WB_API_BASE_URL=https://statistics-api.wildberries.ru
WB_API_TIMEOUT_SEC=30
WB_API_POLL_INTERVAL_SEC=60
WB_API_BATCH_HOUR=3
WB_API_MORNING_HOUR=9
WB_API_MORNING_MINUTE=0
WB_API_RUN_BATCH_ON_START=1

BOT_NAME=NeuroMule
CHANNEL_ID=@mulendeeva_ai
CHANNEL_URL=https://t.me/mulendeeva_ai
TELEGRAM_BOT_USERNAME=NeuroMule_bot
# Стриминг ответа в одном сообщении (throttle edit_message_text).
TELEGRAM_CHAT_STREAMING=true
TELEGRAM_STREAM_EDIT_INTERVAL_SEC=0.8
SUPPORT_BOT_USERNAME=MuleHelp_bot
# Опционально: ник без @ — появится кнопка «Администратор» в поддержке.
# ADMIN_USERNAME=
# Скрытая админ-панель: список Telegram user_id через запятую.
ADMIN_IDS=
# Владелец команды /admin_stats (финансовый пульс). Если пусто — первый id из ADMIN_IDS.
ADMIN_TELEGRAM_ID=
# Курс $→₽ для /admin_stats (по умолчанию 95).
ADMIN_STATS_USD_RUB_RATE=95
# 1 = считать Gemini Flash платным на OpenRouter; 0 = бесплатный шлюз ($0)
OPENROUTER_GEMINI_BILLABLE=0
# God Mode: 1 = супер-админы (ADMIN_IDS) не тратят ⚡/💎 при тестах; 0 = прод (по умолчанию)
GOD_MODE_ENABLED=0
# Чат для тикетов поддержки (группа/супергруппа). Если задан — обращения идут сюда, иначе в ADMIN_IDS.
ADMIN_CHAT_ID=
# Ссылка на Telegra.ph-инструкцию (кнопка «📖 Инструкция и Гайды» в поддержке).
SUPPORT_INSTRUCTION_URL=https://telegra.ph/NeuroMule---Rukovodstvo-polzovatelya-05-20

# Промокоды при старте: CODE:energy_bonus:max_uses (через запятую)
PROMO_SEEDS=
FREE_DAILY_PHOTO_LIMIT=3
FREE_DAILY_CHAT_LIMIT=30
FREE_DAILY_TEXT_LIMIT=30
ENERGY_LOW_THRESHOLD=50
COST_ANIMATE_VIDEO_SUGGEST=20

COST_TEXT_PRO=10
COST_IMAGE_PRO=3
COST_ANIMATE=20
COST_VIDEO=20
COST_MUSIC=15
COST_HD=70
COST_MATCH=50
COST_UPSCALE=1
REFERRAL_BONUS_ENERGY=5

# Чат: стандарт 1⚡/1💎, эксперт 5⚡/3💎
COST_CHAT_STANDARD_ENERGY=1
COST_CHAT_STANDARD_CRYSTALS=1
COST_CHAT_EXPERT_ENERGY=5
COST_CHAT_EXPERT_CRYSTALS=3
DAILY_FREE_ENERGY=30

# Видео-сценарии (💎): PRO 35, extend 30, long 100; пранки 50/70/80/100
COST_VIDEO_PRO_5SEC=35
COST_VIDEO_EXTEND=30
COST_VIDEO_LONG=100
COST_VIDEO_TIER_50=50
COST_VIDEO_TIER_70=70
COST_VIDEO_TIER_80=80
COST_VIDEO_TIER_100=100
COST_VIDEO_CUSTOM_TEXT=40
COST_VIDEO_CUSTOM_PHOTO=50
COST_VIDEO_CUSTOM_VIDEO=80
COST_IMAGE_DALLE_CRYSTALS=5
FREE_IMAGEN_OVERLIMIT_COST=2
PAID_IMAGEN_ENERGY_COST=10
PAID_IMAGEN_CRYSTAL_COST=2
PAID_FLUX_ENERGY_COST=30
PAID_FLUX_CRYSTAL_COST=3
PAID_BANANA2_ENERGY_COST=15
PAID_BANANA2_CRYSTAL_COST=2
PAID_BANANA_PRO_ENERGY_COST=35
PAID_BANANA_PRO_CRYSTAL_COST=3

# ─── TOS-gate: 3 юридических документа на Telegra.ph ──────────────────────
# Эти три ссылки встроены в первое HTML-приветствие после /start и
# проверяются в config.URL_PUBLIC_OFFER / URL_PRIVACY_POLICY /
# URL_SUBSCRIPTION_TERMS. Пользователь принимает их единственной кнопкой
# «✅ Принять условия и Запустить» (callback accept_legal_tos).
SERVICE_OFFER_URL=https://telegra.ph/Publichnaya-oferta-servisa-NeuroMule-05-20
PRIVACY_POLICY_URL=https://telegra.ph/Politika-konfidencialnosti-servisa-NeuroMule-05-20
SUBSCRIPTION_TERMS_URL=https://telegra.ph/Usloviya-regulyarnyh-platezhej-i-podpiski-NeuroMule-05-20

# ─── WebApp Mini-App (Telegram / VK / MAX Messenger) ──────────────────────
# Центральный URL фронтенда (статика). Используется одновременно как
# магазин тарифов и как витрина «Галерея NeuroMule 2026». Пусто = WebApp
# кнопки в кабинете деградируют в обычные callback'и (старая UX-ветка).
WEBAPP_SHOP_URL=
WEBAPP_GALLERY_URL=
# URL для нативной кнопки «📱 Studio» (MenuButtonWebApp). Если пусто — берётся WEBAPP_SHOP_URL или база WEBAPP_TABLE_REPORTS_URL.
WEBAPP_STUDIO_URL=
# GitHub Pages фронт интерактивных таблиц. Плейсхолдер {report_id} или база без query.
WEBAPP_TABLE_REPORTS_URL=https://your-user.github.io/neuromule-table/?report_id={report_id}
# Публичный URL FastAPI (NEUROMULE_PLATFORM=api). Подставляется в ссылку Mini App как api_base.
# Пример: http://127.0.0.1:8000 или https://api.neuromule.example.com
MINI_APP_API_BASE_URL=
# CORS Mini App API: явный список origin (через запятую). ``*`` небезопасен с credentials.
# Пример: MINI_APP_CORS_ORIGINS=https://your-user.github.io
MINI_APP_CORS_ORIGINS=

# Comma-separated list of model IDs.
# Free-модели OpenRouter (обновляйте при 400 «not a valid model ID»):
# Без суффикса :free — у OpenRouter многие free-endpoint сняты (404). Резерв: flash-lite.
FREE_MODELS=google/gemini-2.5-flash,google/gemini-2.5-flash-lite
SMART_MODELS=google/gemini-2.5-flash
FREE_TEXT_MODEL=google/gemini-2.5-flash
PAID_TEXT_MODEL=google/gemini-2.5-flash
FREE_IMAGE_MODEL=imagen4

# Текст про ожидание при генерации фото/видео/музыки/оживления (одна строка).
GEN_WAIT_NOTE=Подождите 1–3 минуты — генерация занимает время.

# История чата с LLM: сколько последних реплик в контекст, лимит символов одного сообщения, обрезка архива, rate limit.
CHAT_HISTORY_LIMIT=10
CHAT_MAX_MESSAGE_CHARS=8000
DIALOG_PRUNE_KEEP=50
CHAT_RATE_LIMIT_PER_MINUTE=30
OPENROUTER_TIMEOUT_SEC=45

# Имена как у pydantic-settings (поля Settings в UPPER_SNAKE_CASE).
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_CONSOLE=true
REDIS_URL=
DB_PATH=/app/data/neuromule_base.db

# Docker Compose (тома для /app/data и /app/logs). По умолчанию — именованные neuromule_*.
# Для путей на хосте Linux (бэкап с диска без docker volume):
# NM_DATA_VOL=/opt/neuromule/data
# NM_LOGS_VOL=/opt/neuromule/logs

# Оценка и лимит контекста чата; нарезка длинного ответа в Telegram.
CHAT_CHAR_PER_TOKEN_EST=3
CHAT_MAX_CONTEXT_TOKENS_EST=24000
CHAT_CHUNK_REPLY_THRESHOLD=3500
CHAT_REPLY_CHUNK_SIZE=3900

# Подсчёт токенов: tiktoken (cl100k_base / o200k_base и др.) или false — только CHAT_CHAR_PER_TOKEN_EST.
CHAT_USE_TIKTOKEN=true
TIKTOKEN_ENCODING=cl100k_base

# Фоновая очередь записи assistant+prune в SQLite при старте Telegram-бота.
DIALOG_WRITE_WORKER_ENABLED=true

# Генерация медиа (services/generation_jobs.py): фото/оживление через Replicate, музыка — Suno или прокси.
REPLICATE_API_TOKEN=your_replicate_api_token
# Модели Replicate (owner/name): текст→видео и image→video для оживления.
REPLICATE_VIDEO_MODEL=luma/ray-flash
REPLICATE_ANIMATE_MODEL=luma/ray-flash
REPLICATE_POLL_INTERVAL_SEC=3
REPLICATE_POLL_TIMEOUT_SEC=600
# Suno API или совместимый прокси (эндпоинт POST {SUNO_API_URL}/generate).
SUNO_API_TOKEN=your_suno_api_token
SUNO_API_URL=https://your-suno-proxy.example.com
SUNO_MAKE_INSTRUMENTAL=false
SUNO_WAIT_AUDIO=true
SUNO_REQUEST_TIMEOUT_SEC=300

# ─── OpenAI TTS (озвучка подкастов role="podcast_doc") ─────────────────────
# Модель ``tts-1`` голосом ``alloy``; ключ берётся из OPENAI_API_KEY.
OPENAI_API_KEY=your_openai_api_key

# ─── Reviews модерация (+5 ⚡ за отзыв) ────────────────────────────────────
# Закрытый чат-админка модерации (группа/супергруппа), в которую падают
# отзывы пользователей с inline-кнопками «✅ Одобрить» / «❌ Отклонить».
# Формат: отрицательный для супергруппы (-100…), целое для приватной группы.
REVIEWS_ADMIN_CHAT_ID=
# Бонус Энергии за оставленный отзыв (по умолчанию 5 ⚡).
REVIEW_ENERGY_BONUS=5

# ─── Премодерация Галереи (защита от NSFW в публичных каналах) ────────────
# Отдельный модерационный чат для PRE-публикационной проверки контента
# (фото/видео/музыка от пользователей). Если ПУСТО — система деградирует
# в авто-публикацию (с предупреждением в логах). Рекомендация: всегда
# задавайте свой ID супергруппы для боевых каналов.
GALLERY_MODERATION_CHAT_ID=

# ─── Observability: HTTP-эндпоинт метрик (PR-K) ───────────────────────────
# 0 = выключен (по умолчанию). При значении > 0 в Telegram-процессе
# поднимается лёгкий FastAPI-sidecar на http://127.0.0.1:{port}/metrics/json
# и /health. Bind строго loopback — экспозиция наружу только через
# reverse-proxy (nginx/traefik) с auth-basic.
METRICS_HTTP_PORT=0

# ─── PostgreSQL pool (PR-P, DRAFT — пока не активен) ──────────────────────
# Если POSTGRES_DSN пуст → используется legacy SQLite (текущий прод).
# Активация по фазам, см. docs/MIGRATION_POSTGRES.md.
# Формат: postgresql://user:pass@host:5432/dbname (?sslmode=require)
POSTGRES_DSN=
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10
# Жёсткий таймаут на ЛЮБОЙ SQL-запрос. Не повышать без нагрузочного теста.
POSTGRES_COMMAND_TIMEOUT_SEC=5.0

# ─── Галерея NeuroMule 2026 (публичный кросс-постинг шедевров) ────────────
# Telegram-канал/супергруппа галереи. Принимается @username или числовой id
# (для приватного канала — отрицательный -100…).
GALLERY_CHANNEL_ID=

# ─── ВКонтакте (cross-post в группу: фото/видео/аудио) ────────────────────
# Токен сообщества с правами photos + wall + video + audio.
VK_GROUP_TOKEN=
# Числовой ID группы (без минуса; код сам подставит -id для owner_id wall).
VK_GROUP_ID=
# ID альбомов внутри группы для маршрутизации контента.
VK_PHOTO_ALBUM_ID=
VK_VIDEO_ALBUM_ID=
# Короткая ссылка-возврат в TG-бота (vk.cc/...). Подставляется в описания постов.
VK_SHARE_SHORT_URL=https://vk.cc/neuromule_bot

# ─── MAX App (лента коротких ИИ-видео) ────────────────────────────────────
# Bearer-токен авторизации feed-аплоадера.
MAX_API_TOKEN=
# Endpoint multipart/form-data POST (video + caption + source_link).
MAX_API_URL=https://maxapp.ru/api/v1/feed/upload
