TG_TOKEN=your_telegram_bot_token

# ЮKassa: токен провайдера из @BotFather (раздел Payments). Пусто — только Stars.
# Можно использовать PAYMENT_TOKEN или UKASSA_PROVIDER_TOKEN.
PAYMENT_TOKEN=
UKASSA_PROVIDER_TOKEN=
SHOP_PAYMENT_TITLE=NeuroMule

# Тарифы MINI/SMART/ULTRA.
MINI_ENERGY=500
MINI_CRYSTALS=10
MINI_RUB_KOPECKS=29000
MINI_STARS=210
SMART_ENERGY=1500
SMART_CRYSTALS=35
SMART_RUB_KOPECKS=69000
SMART_STARS=490
ULTRA_ENERGY=7000
ULTRA_CRYSTALS=120
ULTRA_RUB_KOPECKS=199000
ULTRA_STARS=1450
CRYSTALS_10_AMOUNT=10
CRYSTALS_10_RUB_KOPECKS=19900
CRYSTALS_10_STARS=145
CRYSTALS_40_AMOUNT=40
CRYSTALS_40_RUB_KOPECKS=49000
CRYSTALS_40_STARS=355
CRYSTALS_100_AMOUNT=100
CRYSTALS_100_RUB_KOPECKS=99000
CRYSTALS_100_STARS=720
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_CHAT_URL=https://openrouter.ai/api/v1/chat/completions
GEMINI_API_KEY=your_google_ai_key
# Лимит выходных токенов (тело запроса max_tokens); имена env = полям Settings в UPPER_CASE.
OPENROUTER_MAX_OUTPUT_TOKENS=640

# telegram | vk | max | api
NEUROMULE_PLATFORM=telegram
VK_TOKEN=
MAX_TOKEN=
API_PORT=8000

BOT_NAME=NeuroMule
CHANNEL_ID=@mulendeeva_ai
CHANNEL_URL=https://t.me/mulendeeva_ai
TELEGRAM_BOT_USERNAME=NeuroMule_bot
# Стриминг ответа в одном сообщении (throttle edit_message_text).
TELEGRAM_CHAT_STREAMING=true
TELEGRAM_STREAM_EDIT_INTERVAL_SEC=0.8
SUPPORT_BOT_USERNAME=MuleHelp_bot
# Опционально: ник без @ — появится кнопка «Администратор» в поддержке.
# ADMIN_USERNAME=
# Скрытая админ-панель: список Telegram user_id через запятую.
ADMIN_IDS=

# Промокоды при старте: CODE:energy_bonus:max_uses (через запятую)
PROMO_SEEDS=
FREE_DAILY_PHOTO_LIMIT=3
FREE_DAILY_CHAT_LIMIT=30
FREE_DAILY_TEXT_LIMIT=30
ENERGY_LOW_THRESHOLD=50
COST_ANIMATE_VIDEO_SUGGEST=20

COST_TEXT_PRO=10
COST_IMAGE_PRO=2
COST_ANIMATE=20
COST_VIDEO=20
COST_MUSIC=5
COST_HD=70
COST_MATCH=50
COST_UPSCALE=1
REFERRAL_BONUS_ENERGY=50

SERVICE_OFFER_URL=https://telegra.ph/Polzovatelskoe-soglashenie-i-Oferta-04-30
PRIVACY_POLICY_URL=https://telegra.ph/Politika-konfidencialnosti-Obrabotka-personalnyh-dannyh-04-30-2
SUBSCRIPTION_TERMS_URL=https://telegra.ph/Soglashenie-o-rekurrentnyh-platezhah-Podpiska-04-30-2

# Comma-separated list of model IDs.
FREE_MODELS=google/gemini-2.0-flash-lite-preview-02-05:free,google/gemini-2.0-pro-exp-02-05:free,mistralai/mistral-7b-instruct:free,openrouter/auto
SMART_MODELS=openrouter/auto
FREE_TEXT_MODEL=google/gemini-2.0-flash-lite:free
FREE_IMAGE_MODEL=flux-schnell

# Текст про ожидание при генерации фото/видео/музыки/оживления (одна строка).
GEN_WAIT_NOTE=Подождите 1–3 минуты — генерация занимает время.

# История чата с LLM: сколько последних реплик в контекст, лимит символов одного сообщения, обрезка архива, rate limit.
CHAT_HISTORY_LIMIT=10
CHAT_MAX_MESSAGE_CHARS=8000
DIALOG_PRUNE_KEEP=50
CHAT_RATE_LIMIT_PER_MINUTE=30
OPENROUTER_TIMEOUT_SEC=45

# Имена как у pydantic-settings (поля Settings в UPPER_SNAKE_CASE).
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_CONSOLE=true
REDIS_URL=
DB_PATH=/app/data/neuromule_base.db

# Docker Compose (тома для /app/data и /app/logs). По умолчанию — именованные neuromule_*.
# Для путей на хосте Linux (бэкап с диска без docker volume):
# NM_DATA_VOL=/opt/neuromule/data
# NM_LOGS_VOL=/opt/neuromule/logs

# Оценка и лимит контекста чата; нарезка длинного ответа в Telegram.
CHAT_CHAR_PER_TOKEN_EST=3
CHAT_MAX_CONTEXT_TOKENS_EST=24000
CHAT_CHUNK_REPLY_THRESHOLD=3500
CHAT_REPLY_CHUNK_SIZE=3900

# Подсчёт токенов: tiktoken (cl100k_base / o200k_base и др.) или false — только CHAT_CHAR_PER_TOKEN_EST.
CHAT_USE_TIKTOKEN=true
TIKTOKEN_ENCODING=cl100k_base

# Фоновая очередь записи assistant+prune в SQLite при старте Telegram-бота.
DIALOG_WRITE_WORKER_ENABLED=true

# Генерация медиа (services/generation_jobs.py): фото/оживление через Replicate, музыка — Suno или прокси.
REPLICATE_API_TOKEN=your_replicate_api_token
# Модели Replicate (owner/name): текст→видео и image→video для оживления.
REPLICATE_VIDEO_MODEL=luma/ray-flash
REPLICATE_ANIMATE_MODEL=luma/ray-flash
REPLICATE_POLL_INTERVAL_SEC=3
REPLICATE_POLL_TIMEOUT_SEC=600
# Suno API или совместимый прокси (эндпоинт POST {SUNO_API_URL}/generate).
SUNO_API_TOKEN=your_suno_api_token
SUNO_API_URL=https://your-suno-proxy.example.com
SUNO_MAKE_INSTRUMENTAL=false
SUNO_WAIT_AUDIO=true
SUNO_REQUEST_TIMEOUT_SEC=300
